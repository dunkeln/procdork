{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"experimentalServices": {
		"web": {
			"entrypoint": "web",
			"routePrefix": "/",
			"framework": "sveltekit",
			"maxDuration": 60
		},
		"ingestion": {
			"entrypoint": "microservices/app.py",
			"routePrefix": "/svc/ingestion",
			"maxDuration": 60,
			"excludeFiles": "{tests/**,**/tests/**,**/.venv/**,**/__pycache__/**}"
		}
	}
}
