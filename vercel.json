{
	"$schema": "https://openapi.vercel.sh/vercel.json",
	"services": {
		"web": {
			"root": "web",
			"framework": "sveltekit"
		},
		"ingestion": {
			"root": "microservices",
			"entrypoint": "app:app",
			"framework": "fastapi",
			"routes": [
				{
					"src": "/svc/ingestion/(.*)",
					"transforms": [
						{
							"type": "request.path",
							"op": "set",
							"args": "/$1"
						}
					]
				}
			]
		}
	},
	"rewrites": [
		{ "source": "/svc/ingestion/(.*)", "destination": { "service": "ingestion" } },
		{ "source": "/(.*)", "destination": { "service": "web" } }
	]
}
