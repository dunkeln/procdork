      "boundElements": null,
      "updated": 1784076566820,
      "link": null,
      "locked": false,
      "text": "dlt is a effective solution when sources are structured enough.\nAirflow, Fivetran, and Airbyte are great when the problem is managed operations and connectors.\nHere the problem is reducing glue: infer the schema and flatten the records.",
      "fontSize": 16,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "dlt is a effective solution when sources are structured enough.\nAirflow, Fivetran, and Airbyte are great when the problem is managed operations and connectors.\nHere the problem is reducing glue: infer the schema and flatten the records.",
      "autoResize": true,
      "lineHeight": 1.25
    },
